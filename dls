# Step 3 — Shooting System

Create:

```text
Scripts/Player/PlayerShoot.cs
```

```csharp
using UnityEngine;

public class PlayerShoot : MonoBehaviour
{
    public BallController ball;

    public float shootPower = 20f;

    void Update()
    {
        if (Input.GetKeyDown(KeyCode.Space))
        {
            Shoot();
        }
    }

    void Shoot()
    {
        Vector3 shootDirection = transform.forward + Vector3.up * 0.2f;

        ball.KickBall(shootDirection.normalized, shootPower);
    }
}
```

