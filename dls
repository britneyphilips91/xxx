```text
Scripts/Player/PlayerPass.cs
```

```csharp
using UnityEngine;

public class PlayerPass : MonoBehaviour
{
    public BallController ball;

    public float passPower = 10f;

    void Update()
    {
        if (Input.GetKeyDown(KeyCode.E))
        {
            PassBall();
        }
    }

    void PassBall()
    {
        Vector3 passDirection = transform.forward;

        ball.KickBall(passDirection.normalized, passPower);
    }
}
```

